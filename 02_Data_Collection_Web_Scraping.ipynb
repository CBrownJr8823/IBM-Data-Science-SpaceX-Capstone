import folium

# Center the map around NASA
site_map = folium.Map(location=[28.5623, -80.5773], zoom_start=5)

# Add a marker for a Launch Site (Example: KSC LC-39A)
# 1 = Green (Success), 0 = Red (Failure)
marker = folium.Marker(
    [28.573255, -80.646895], 
    icon=folium.Icon(color='green', icon='info-sign'),
    popup='KSC LC-39A - Success'
)
marker.add_to(site_map)
site_map.save("launch_site_map.html") # Open this file to see your map
