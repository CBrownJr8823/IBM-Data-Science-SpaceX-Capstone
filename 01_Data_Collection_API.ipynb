import pandas as pd
import sqlite3

# Load your cleaned dataset
df = pd.read_csv('spacex_web_scraped.csv')
conn = sqlite3.connect('my_data.db')
df.to_sql('SPACEXTBL', conn, if_exists='replace', index=False, method="multi")

# Example Query for Requirement 1.12 (Success rates by launch site)
query = """
SELECT Launch_Site, AVG(Class) as Success_Rate 
FROM SPACEXTBL 
GROUP BY Launch_Site
"""
df_sql = pd.read_sql(query, conn)
print(df_sql)
